# Copy to .env (gitignored) and adjust values. Cursor/VS Code can load .env into the integrated terminal via .vscode/settings.json when this folder is the workspace root.
OCP_SERVER=https://api.xxxxxxxxxxxxxx:6443
OCP_USERNAME=xxxxxxxxxxxxx
OCP_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitOps phase 1–2: HTTPS clone URL for the repo that contains this bootstrap tree (branch below).
GITHUB_URL=https://github.com/yourorg/your-bootstrap-repo.git
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
# Optional; must match a branch or tag ApplicationSet + init job will sync
GITHUB_REVISION=main
