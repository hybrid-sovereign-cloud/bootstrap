# Copy to .env (gitignored) and adjust values.
# Alternatively, add all of these to ~/.bashrc for persistent sessions.
#
# Cursor Cloud Agents: add the same names in Dashboard → Cloud Agents → Secrets.

# --- OpenShift Cluster Access (REQUIRED) ---
OCP_SERVER=https://api.<cluster-domain>:6443
OCP_USERNAME=<admin-username>
OCP_PASSWORD=<admin-password>

# --- OCI Registry (REQUIRED for Helm chart push/pull from Quay.io) ---
# OCI_REGISTRY: full URL to the Quay organization
OCI_REGISTRY=https://quay.io/organization/sovereignhybrid
# OCI_REGISTRY_TOKEN: Quay.io robot account OAuth token (not the robot password — use the OAuth token)
# Obtain: quay.io → Organization → Robot Accounts → <robot> → Token
OCI_REGISTRY_TOKEN=<quay-robot-oauth-token>

# --- GitHub Token (REQUIRED for operator build pipelines) ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- Optional Overrides ---
# GitOps phase 1-2: HTTPS clone URL for the bootstrap repo.
GITHUB_URL=https://github.com/hybrid-sovereign-cloud/bootstrap.git
# Git revision (default: main)
GITHUB_REVISION=main
